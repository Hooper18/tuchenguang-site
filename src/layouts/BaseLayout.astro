---
import '../styles/global.css';
import { getDict, htmlLangAttr, switchLangHref, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
  /** Path of this page in the OTHER language. Used for hreflang alternate AND
   *  Nav's lang switch. Defaults to the mirror computed from current path.
   *  Pages where the other-language version doesn't exist as a true translation
   *  (e.g. an orphan blog post) should set hasAltLang=false and pass a sane
   *  fallback path here. */
  altLangHref?: string;
  /** Whether the other language has a real translation of this page. When false,
   *  the hreflang link for the other language is omitted (Nav still renders the
   *  lang switch with the fallback URL). Default true. */
  hasAltLang?: boolean;
  /** Suppress canonical / hreflang / sitemap inclusion. Used by 404. */
  noIndex?: boolean;
}

const {
  lang = 'zh',
  title,
  description,
  ogImage = '/images/og-image.png',
  altLangHref,
  hasAltLang = true,
  noIndex = false,
} = Astro.props;

const t = getDict(lang);
const finalTitle = title ?? t.baseMeta.title;
const finalDesc = description ?? t.baseMeta.description;
const htmlLang = htmlLangAttr(lang);

// Build absolute URLs for hreflang/canonical. Astro.site is configured to
// 'https://tuchenguang.com' in astro.config.mjs.
const site = Astro.site!;
const currentPath = Astro.url.pathname;
const otherPath = altLangHref ?? switchLangHref(currentPath, lang);
const zhPath = lang === 'zh' ? currentPath : otherPath;
const enPath = lang === 'en' ? currentPath : otherPath;
const zhUrl = new URL(zhPath, site).toString();
const enUrl = new URL(enPath, site).toString();
const canonicalUrl = lang === 'zh' ? zhUrl : enUrl;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{finalTitle}</title>
    <meta name="description" content={finalDesc} />
    {noIndex && <meta name="robots" content="noindex" />}
    {!noIndex && (
      <>
        <link rel="canonical" href={canonicalUrl} />
        {/* hreflang for current language always emitted; other language only when a real translation exists */}
        {lang === 'zh' && <link rel="alternate" hreflang="zh-CN" href={zhUrl} />}
        {lang === 'en' && <link rel="alternate" hreflang="en" href={enUrl} />}
        {hasAltLang && lang === 'zh' && <link rel="alternate" hreflang="en" href={enUrl} />}
        {hasAltLang && lang === 'en' && <link rel="alternate" hreflang="zh-CN" href={zhUrl} />}
        <link rel="alternate" hreflang="x-default" href={zhUrl} />
      </>
    )}
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={t.blog.rssTitle}
      href={lang === 'zh' ? '/rss.xml' : '/en/rss.xml'}
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  // 鼠标柔光
  document.addEventListener('mousemove', (e) => {
    document.documentElement.style.setProperty('--mouse-x', e.clientX + 'px');
    document.documentElement.style.setProperty('--mouse-y', e.clientY + 'px');
  });

  // Nav scroll
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    });
  }

  // Reveal observer
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
