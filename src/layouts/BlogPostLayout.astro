---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SideLeft from '../components/SideLeft.astro';
import SideRight from '../components/SideRight.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} — 涂晨光`} description={description}>
  <Nav />
  <SideLeft />
  <SideRight />
  <main class="blog-main">
    <article class="blog-article">
      <header class="blog-header reveal">
        <a href="/blog" class="back-link">← 返回博客</a>
        <h1 class="blog-title">{title}</h1>
        <div class="blog-meta">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {updatedDate && <span>· 更新于 <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>}
        </div>
        {tags.length > 0 && (
          <ul class="blog-tags">
            {tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
      </header>
      <div class="blog-content reveal">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-main {
    padding: 0 100px;
    max-width: 1400px;
    margin: 0 auto;
    padding-top: 120px;
    padding-bottom: 100px;
  }
  .blog-article {
    max-width: 700px;
    margin: 0 auto;
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    text-decoration: none;
    margin-bottom: 30px;
    transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 0.7; }
  .blog-title {
    font-size: clamp(28px, 5vw, 42px);
    color: var(--slate-light);
    font-weight: 600;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .blog-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--slate);
    margin-bottom: 16px;
  }
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin-bottom: 50px;
  }
  .blog-tags li {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 3px;
    padding: 2px 10px;
  }
  .blog-content {
    border-top: 1px solid var(--slate-dark);
    padding-top: 40px;
    color: var(--slate);
    font-size: 16px;
    line-height: 1.8;
  }
  .blog-content :global(h2),
  .blog-content :global(h3),
  .blog-content :global(h4) {
    color: var(--slate-light);
    font-weight: 600;
    margin: 40px 0 16px;
    letter-spacing: -0.01em;
  }
  .blog-content :global(h2) { font-size: 24px; }
  .blog-content :global(h3) { font-size: 20px; }
  .blog-content :global(p) { margin-bottom: 20px; }
  .blog-content :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .blog-content :global(a:hover) { border-bottom-color: var(--accent); }
  .blog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--bg-light);
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--accent);
  }
  .blog-content :global(pre) {
    background: var(--bg-light);
    padding: 20px;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 20px;
    border: 1px solid var(--slate-dark);
  }
  .blog-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--slate-light);
  }
  .blog-content :global(ul),
  .blog-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .blog-content :global(li) { margin-bottom: 8px; }
  .blog-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 20px;
    margin: 20px 0;
    color: var(--slate);
    font-style: italic;
  }
  .blog-content :global(img) {
    max-width: 100%;
    border-radius: 4px;
    margin: 20px 0;
  }
  @media (max-width: 1099px) {
    .blog-main { padding: 120px 50px 100px; }
  }
  @media (max-width: 699px) {
    .blog-main { padding: 100px 20px 80px; }
  }
</style>
