---
// 静态站只能生成一个 404.html。Vercel 把它作为兜底 —— /xxx 和 /en/xxx 不存在
// 时都会落到这里。所以同一份页面里渲染中英两段，开头一段 inline script 按
// location.pathname 切显隐 + 改 <html lang>。Nav 用默认 zh，进入 /en/* 时
// 由脚本同步切到英文版（见 BaseLayout 的 hydration 路径）。
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SideLeft from '../components/SideLeft.astro';
import SideRight from '../components/SideRight.astro';
import Footer from '../components/Footer.astro';
import { zh } from '../i18n/zh';
---

<BaseLayout
  lang="zh"
  title="404"
  description={zh.baseMeta.description}
  altLangHref="/en/"
  hasAltLang={false}
  noIndex
>
  <Nav lang="zh" langSwitchHref="/en/" />
  <SideLeft />
  <SideRight />
  <main class="not-found">
    <div data-lang-block="zh">
      <p class="code">404</p>
      <h1>页面不见了</h1>
      <p class="hint">链接可能失效，或者页面已经移走。</p>
      <a href="/" class="back-link">回首页 ↗</a>
    </div>
    <div data-lang-block="en" hidden>
      <p class="code">404</p>
      <h1>Page not found</h1>
      <p class="hint">The link may be broken, or the page has moved.</p>
      <a href="/en/" class="back-link">Back home ↗</a>
    </div>
  </main>
  <Footer lang="zh" />
</BaseLayout>

<script is:inline>
  (function () {
    var isEn = location.pathname.indexOf('/en/') === 0 || location.pathname === '/en';
    if (!isEn) return;
    document.documentElement.lang = 'en';
    var zhBlock = document.querySelector('[data-lang-block="zh"]');
    var enBlock = document.querySelector('[data-lang-block="en"]');
    if (zhBlock) zhBlock.hidden = true;
    if (enBlock) enBlock.hidden = false;
  })();
</script>

<style>
  .not-found {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 20px 80px;
  }
  .not-found > div {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .code {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .not-found h1 {
    font-size: clamp(28px, 5vw, 40px);
    color: var(--slate-light);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .hint {
    font-size: 15px;
    color: var(--slate);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 24px;
  }
  .back-link {
    display: inline-block;
    padding: 14px 24px;
    border: 1px solid var(--accent);
    border-radius: 4px;
    color: var(--accent);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 13px;
    transition: background 0.2s;
  }
  .back-link:hover { background: var(--accent-dim); }
</style>
