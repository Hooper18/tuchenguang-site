---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SideLeft from '../components/SideLeft.astro';
import SideRight from '../components/SideRight.astro';
import Apps from '../components/Apps.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="应用下载 — 涂晨光"
  description="4 个我自己做的 Android 应用：课程日历、口袋记账、追分记、Tuner。安装包直接装手机用。"
  ogImage="/og-apps.png"
>
  <Nav />
  <SideLeft />
  <SideRight />
  <main>
    <section id="apps">
      <h1 class="page-heading"><span class="num">03.</span>应用下载</h1>
      <p class="page-intro">
        <strong>在线同步</strong>的 web 改完自动升级；<strong>完全离线</strong>的没网也能开。
      </p>
      <Apps />
      <p class="install-hint">
        手机浏览器打开本页点「下载 APK」。Android 拦未知来源时去「设置 → 应用与权限」放行。
      </p>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: 130px;
    padding-bottom: 80px;
  }
  .page-heading {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: clamp(28px, 5vw, 36px);
    color: var(--slate-light);
    font-weight: 600;
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }
  .page-heading .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 22px;
    font-weight: 400;
  }
  .page-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--slate-dark);
    max-width: 300px;
    margin-left: 20px;
  }
  .page-intro {
    color: var(--slate);
    font-size: 16px;
    line-height: 1.75;
    max-width: 720px;
    margin-bottom: 32px;
  }
  .page-intro strong {
    color: var(--slate-light);
    font-weight: 500;
  }
  .install-hint {
    margin-top: 40px;
    color: var(--slate);
    font-size: 13px;
    line-height: 1.75;
    text-align: center;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  @media (max-width: 699px) {
    main { padding-top: 100px; }
  }
</style>
