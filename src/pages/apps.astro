---
import { statSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SideLeft from '../components/SideLeft.astro';
import SideRight from '../components/SideRight.astro';
import Footer from '../components/Footer.astro';

// 构建时从 cwd 读 APK 大小，cwd 在 astro build 时就是项目根目录。
const downloadsDir = resolve(process.cwd(), 'public/downloads');

function sizeOf(file: string) {
  const bytes = statSync(resolve(downloadsDir, file)).size;
  return (bytes / 1024 / 1024).toFixed(1) + ' MB';
}

interface AppEntry {
  slug: string;
  name: string;
  iconAlt: string;
  desc: string;
  badge: string;
  apk: string;
  webUrl?: string;
}

const apps: AppEntry[] = [
  {
    slug: 'schedule',
    name: '课程日历',
    iconAlt: '课程日历应用图标',
    desc: '学校 DDL 与课程管理。多平台支付时代的课业总账，支持月/周/列表视图，离线优先。',
    badge: '在线同步',
    apk: 'schedule-v0.1.0.apk',
    webUrl: 'https://calendar.tuchenguang.com',
  },
  {
    slug: 'ledger',
    name: '口袋记账',
    iconAlt: '口袋记账应用图标',
    desc: '多币种记账与预算管理。统计、日历、汇率换算全部免费，不用开会员。',
    badge: '在线同步',
    apk: 'ledger-v0.1.0.apk',
    webUrl: 'https://ledger.tuchenguang.com',
  },
  {
    slug: 'billiards',
    name: '追分记',
    iconAlt: '追分记应用图标',
    desc: '三人台球计分。逻辑简洁、零广告，朋友局碎片化记账用。',
    badge: '完全离线',
    apk: 'billiards-v0.1.0.apk',
    webUrl: 'https://billiards.tuchenguang.com',
  },
  {
    slug: 'tuner',
    name: 'Tuner',
    iconAlt: '吉他调音器应用图标',
    desc: '半音吉他调音器，YIN 算法做基频检测，本地运行不需要联网。',
    badge: '完全离线',
    apk: 'tuner-v0.1.0.apk',
    webUrl: 'https://tuner.tuchenguang.com',
  },
];
---

<BaseLayout title="应用下载 — 涂晨光" description="我自己做的几个 Android 应用，扫一扫装在手机上用。">
  <Nav />
  <SideLeft />
  <SideRight />
  <main>
    <section id="apps">
      <h1 class="page-heading"><span class="num">06.</span>应用下载</h1>
      <p class="page-intro">
        几个我自己做的 Android 应用打包成 APK 直接装手机用。
        <strong>在线同步</strong>的几个用 Capacitor 套了远程 PWA，web 改完手机自动用上新版本；
        <strong>完全离线</strong>的把资源整个塞进 APK，没网也能开。
      </p>

      <ul class="app-list">
        {apps.map((app) => (
          <li class="app-row">
            <img src={`/icons/${app.slug}.png`} alt={app.iconAlt} class="app-icon" loading="lazy" />
            <div class="app-meta">
              <div class="app-headline">
                <h2 class="app-name">{app.name}</h2>
                <span class={`app-badge ${app.badge === '完全离线' ? 'badge-offline' : 'badge-sync'}`}>
                  {app.badge}
                </span>
              </div>
              <p class="app-desc">{app.desc}</p>
              <div class="app-info">
                <span>v0.1.0</span>
                <span class="dot">·</span>
                <span>{sizeOf(app.apk)}</span>
                {app.webUrl && (
                  <>
                    <span class="dot">·</span>
                    <a href={app.webUrl} target="_blank" rel="noopener" class="web-link">网页版 ↗</a>
                  </>
                )}
              </div>
            </div>
            <a href={`/downloads/${app.apk}`} download class="dl-btn">下载 APK</a>
          </li>
        ))}
      </ul>

      <div class="install-hint">
        <h3>安装提示</h3>
        <ol>
          <li>用手机浏览器打开本页直接点「下载 APK」。</li>
          <li>下完 Android 弹「未知来源」拦截，到「设置 → 应用与权限 → 信任此来源」勾上即可。</li>
          <li>第一次安装如果不显示图标，去「桌面 → 应用列表」找一下加到桌面。</li>
        </ol>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: 130px;
    padding-bottom: 80px;
  }
  .page-heading {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: clamp(28px, 5vw, 36px);
    color: var(--slate-light);
    font-weight: 600;
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }
  .page-heading .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 22px;
    font-weight: 400;
  }
  .page-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--slate-dark);
    max-width: 300px;
    margin-left: 20px;
  }
  .page-intro {
    color: var(--slate);
    font-size: 16px;
    line-height: 1.75;
    max-width: 720px;
    margin-bottom: 60px;
  }
  .page-intro strong {
    color: var(--slate-light);
    font-weight: 500;
  }

  .app-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(136, 146, 176, 0.12);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 60px;
  }
  .app-row {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 22px 24px;
    background: var(--bg);
    transition: background 0.2s;
  }
  .app-row:hover {
    background: rgba(17, 34, 64, 0.5);
  }
  .app-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    flex-shrink: 0;
    object-fit: cover;
  }
  .app-meta {
    flex: 1;
    min-width: 0;
  }
  .app-headline {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }
  .app-name {
    font-size: 17px;
    color: var(--slate-light);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .app-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }
  .badge-sync {
    color: var(--accent);
    background: rgba(100, 255, 218, 0.08);
    border: 1px solid rgba(100, 255, 218, 0.25);
  }
  .badge-offline {
    color: var(--slate);
    background: rgba(136, 146, 176, 0.08);
    border: 1px solid rgba(136, 146, 176, 0.2);
  }
  .app-desc {
    font-size: 14px;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 8px;
  }
  .app-info {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .app-info .dot {
    color: var(--slate-dark);
  }
  .web-link {
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
  }
  .web-link:hover { color: var(--accent); }

  .dl-btn {
    flex-shrink: 0;
    padding: 10px 18px;
    border: 1px solid var(--accent);
    border-radius: 4px;
    color: var(--accent);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 13px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .dl-btn:hover { background: var(--accent-dim); }

  .install-hint {
    border: 1px solid var(--slate-dark);
    border-radius: 6px;
    padding: 24px 28px;
  }
  .install-hint h3 {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
  }
  .install-hint ol {
    padding-left: 20px;
    color: var(--slate);
    font-size: 14px;
    line-height: 1.85;
  }
  .install-hint li { margin-bottom: 4px; }

  @media (max-width: 699px) {
    main { padding-top: 100px; }
    .app-row {
      flex-wrap: wrap;
      gap: 16px;
      padding: 18px 16px;
    }
    .app-meta { flex: 1 1 calc(100% - 80px); }
    .dl-btn { flex: 1 1 100%; text-align: center; }
    .app-icon { width: 48px; height: 48px; }
  }
</style>
