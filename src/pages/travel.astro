---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SideLeft from '../components/SideLeft.astro';
import SideRight from '../components/SideRight.astro';
import Footer from '../components/Footer.astro';
import travelData from '../data/travel.json';

type Place = {
  country: string;
  region: string | null;
  city: string;
  lat: number;
  lng: number;
  date: string | null;
  type: 'base' | 'travel';
  note: string | null;
};

const allPlaces = travelData.places as Place[];
const bases = allPlaces.filter(p => p.type === 'base');
const travels = allPlaces
  .filter(p => p.type === 'travel')
  .sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));

// Group travel entries by year (descending)
const byYear: Record<string, Place[]> = {};
for (const p of travels) {
  if (!p.date) continue;
  const year = p.date.slice(0, 4);
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(p);
}
const sortedYears = Object.keys(byYear).sort((a, b) => parseInt(b) - parseInt(a));

function displayLabel(p: Place): string {
  if (p.country === '中国' && p.region) return `${p.region} · ${p.city}`;
  if (p.country === '中国香港') return `香港`;
  if (p.country === '中国澳门') return `澳门`;
  return `${p.country} · ${p.city}`;
}
---

<BaseLayout title="足迹 — 涂晨光" description="走过的地方，记一记。">
  <Nav />
  <SideLeft />
  <SideRight />
  <main class="travel-main">
    <div class="travel-header reveal">
      <h1 class="travel-title"><span class="num">04.</span>足迹</h1>
      <p class="travel-desc">走过的地方，记一记。</p>
    </div>

    <div id="map-tooltip" class="map-tooltip" style="display:none"></div>
    <div class="map-wrap reveal">
      <svg id="travel-map" viewBox="0 0 1000 500" aria-label="世界足迹地图"></svg>
      <div id="map-loading" class="map-loading">地图加载中…</div>
    </div>

    <div class="timeline-section">
      <!-- 根据地 -->
      <div class="year-group reveal">
        <h2 class="year-label">根据地</h2>
        <ul class="place-list">
          {bases.map(p => (
            <li class="place-item base-item">
              <span class="dot base-dot"></span>
              {p.date === null
                ? <span class="place-label">{p.region} · {p.city} · {p.note}</span>
                : <span class="place-label">{p.country} · {p.city} · {p.note} {p.date} 至今</span>
              }
            </li>
          ))}
        </ul>
      </div>

      <!-- 按年份分组 -->
      {sortedYears.map(year => (
        <div class="year-group reveal">
          <h2 class="year-label">{year}</h2>
          <ul class="place-list">
            {byYear[year].map(p => (
              <li class="place-item">
                <span class="dot travel-dot"></span>
                <span class="place-date">{p.date}</span>
                <span class="place-sep"> · </span>
                <span class="place-label">
                  {displayLabel(p)}{p.note ? ` · ${p.note}` : ''}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<script is:inline define:vars={{ places: allPlaces }}>
  window.__travelPlaces = places;
</script>

<script>
  import { geoNaturalEarth1, geoPath, geoArea } from 'd3-geo';
  import { feature, mesh } from 'topojson-client';
  import { zoom, zoomIdentity } from 'd3-zoom';
  import { select } from 'd3-selection';

  type Place = {
    country: string; region: string | null; city: string;
    lat: number; lng: number; date: string | null;
    type: 'base' | 'travel'; note: string | null;
  };

  const places: Place[] = (window as any).__travelPlaces ?? [];

  // Visited non-China-mainland country ISO codes
  const countryToISO: Record<string, number> = {
    '马来西亚': 458, '印度尼西亚': 360, '柬埔寨': 116,
    '日本': 392, '韩国': 410, '新加坡': 702,
  };
  const visitedISOs = new Set<number>();
  places.forEach(p => { if (countryToISO[p.country]) visitedISOs.add(countryToISO[p.country]); });

  // Visited Chinese mainland provinces (region values)
  const visitedRegions = new Set<string>();
  places.filter(p => p.country === '中国' && p.region).forEach(p => visitedRegions.add(p.region!));

  const hasHK = places.some(p => p.country === '中国香港');
  const hasMacau = places.some(p => p.country === '中国澳门');

  const svgEl = document.getElementById('travel-map') as SVGSVGElement | null;
  const loadingEl = document.getElementById('map-loading');
  if (!svgEl) throw new Error('travel-map not found');

  const width = 1000;
  const height = 500;
  let currentZoomK = 1;

  const projection = geoNaturalEarth1().fitSize([width, height], { type: 'Sphere' });
  const pathGen = geoPath().projection(projection);

  function makePath(d: string | null, fill: string, stroke: string, strokeW: number) {
    if (!d) return null;
    const el = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    el.setAttribute('d', d);
    el.setAttribute('fill', fill);
    el.setAttribute('stroke', stroke);
    el.setAttribute('stroke-width', String(strokeW));
    return el;
  }

  try {
    const [worldData, chinaData] = await Promise.all([
      fetch('/data/world-110m.json').then(r => r.json()),
      fetch('/data/china-provinces.json').then(r => r.json()),
    ]);

    const zoomGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    zoomGroup.setAttribute('id', 'zoom-group');
    svgEl.appendChild(zoomGroup);

    // Layer 0: Sphere background (ocean — matches page bg, hides any transparent gaps)
    const sphereBg = makePath(pathGen({ type: 'Sphere' }), '#0a192f', 'none', 0);
    if (sphereBg) {
      sphereBg.dataset.originalStrokeWidth = sphereBg.getAttribute('stroke-width') || '0';
      zoomGroup.appendChild(sphereBg);
    }

    // Layer 1: World countries
    const countries = feature(worldData as any, (worldData as any).objects.countries) as any;
    for (const f of countries.features) {
      const iso = parseInt(String(f.id));
      const isChina = iso === 156;
      let fill: string;
      if (isChina) {
        fill = 'rgba(255,255,255,0.01)'; // China handled by province layer
      } else if (visitedISOs.has(iso)) {
        fill = 'rgba(100,255,218,0.10)';
      } else {
        fill = 'rgba(255,255,255,0.02)';
      }
      const el = makePath(pathGen(f), fill, 'rgba(255,255,255,0.08)', 0.4);
      if (el) {
        el.dataset.originalStrokeWidth = el.getAttribute('stroke-width') || '0';
        zoomGroup.appendChild(el);
      }
    }

    // Layer 1b: Country borders mesh
    const borders = mesh(worldData as any, (worldData as any).objects.countries, (a: any, b: any) => a !== b);
    const borderEl = makePath(pathGen(borders as any), 'none', 'rgba(255,255,255,0.10)', 0.4);
    if (borderEl) {
      borderEl.dataset.originalStrokeWidth = borderEl.getAttribute('stroke-width') || '0';
      zoomGroup.appendChild(borderEl);
    }

    // Layer 2: China province overlay
    // china-provinces.json uses CW ring winding (d3-geo expects CCW per RFC 7946).
    // geoArea returns ~4π for inverted features; reverse all rings to fix winding.
    function rewindFeature(f: any): any {
      const geom = f?.geometry;
      if (!geom) return f;
      const rev = (ring: number[][]) => ring.slice().reverse();
      if (geom.type === 'Polygon') {
        return { ...f, geometry: { ...geom, coordinates: geom.coordinates.map(rev) } };
      }
      if (geom.type === 'MultiPolygon') {
        return { ...f, geometry: { ...geom, coordinates: geom.coordinates.map((poly: number[][][]) => poly.map(rev)) } };
      }
      return f;
    }

    for (const f of (chinaData as any).features) {
      const name: string = f.properties?.name ?? '';
      if (name.includes('台湾')) continue;

      const isHKFeature = name.includes('香港');
      const isMacauFeature = name.includes('澳门');
      const isVisitedProvince = [...visitedRegions].some(r => name.includes(r));

      let fill: string;
      if (isHKFeature && hasHK) fill = 'rgba(100,255,218,0.10)';
      else if (isMacauFeature && hasMacau) fill = 'rgba(100,255,218,0.10)';
      else if (isVisitedProvince) fill = 'rgba(100,255,218,0.06)';
      else fill = 'transparent';

      const fixed = geoArea(f) > 2 * Math.PI ? rewindFeature(f) : f;
      const el = makePath(pathGen(fixed), fill, 'rgba(255,255,255,0.06)', 0.3);
      if (el) {
        el.dataset.originalStrokeWidth = el.getAttribute('stroke-width') || '0';
        zoomGroup.appendChild(el);
      }
    }

    // Layer 3: City dots
    for (const p of places) {
      const coords = projection([p.lng, p.lat]);
      if (!coords) continue;
      const [x, y] = coords;
      if (x < 0 || x > width || y < 0 || y > height) continue;

      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', String(x));
      circle.setAttribute('cy', String(y));
      const isBase = p.type === 'base';
      circle.setAttribute('r', isBase ? '4' : '3');
      circle.setAttribute('fill', isBase ? '#f59e0b' : '#64ffda');
      circle.setAttribute('stroke', isBase ? 'rgba(100,50,0,0.6)' : 'rgba(0,60,50,0.6)');
      circle.setAttribute('stroke-width', '0.8');
      circle.dataset.city = p.city;
      circle.dataset.type = p.type;
      circle.dataset.date = p.date ?? '';
      circle.dataset.country = p.country;
      circle.dataset.note = p.note ?? '';
      circle.style.cursor = 'pointer';

      circle.addEventListener('mouseenter', (e) => {
        const el = e.currentTarget as SVGCircleElement;
        const city = el.dataset.city ?? '';
        const type = el.dataset.type ?? '';
        const date = el.dataset.date ?? '';
        const note = el.dataset.note ?? '';

        let label = city;
        if (type === 'base' && note === '老家') {
          label = `${city} · 老家`;
        } else if (type === 'base' && note === '在读' && date) {
          label = `${city} · 在读 ${date} 至今`;
        } else if (type === 'travel' && date) {
          const [y, m] = date.split('-');
          label = `${city} · ${y} 年 ${Number(m)} 月`;
        }

        const tooltipEl = document.getElementById('map-tooltip');
        if (!tooltipEl) return;
        tooltipEl.textContent = label;
        tooltipEl.style.display = 'block';

        // position: fixed → 直接用 viewport 坐标，不受 overflow: hidden 影响
        const circleRect = el.getBoundingClientRect();
        tooltipEl.style.left = `${circleRect.right + 8}px`;
        tooltipEl.style.top = `${circleRect.top - 28}px`;

        el.setAttribute('stroke', '#64ffda');
        el.setAttribute('stroke-width', String(1 / currentZoomK));
      });

      circle.addEventListener('mouseleave', (e) => {
        const el = e.currentTarget as SVGCircleElement;
        const tooltipEl = document.getElementById('map-tooltip');
        if (tooltipEl) tooltipEl.style.display = 'none';

        const isBase = el.dataset.type === 'base';
        el.setAttribute('stroke', isBase ? 'rgba(100,50,0,0.6)' : 'rgba(0,60,50,0.6)');
        el.setAttribute('stroke-width', String(0.8 / currentZoomK));
      });

      zoomGroup.appendChild(circle);
    }

    const zoomBehavior = zoom<SVGSVGElement, unknown>()
      .scaleExtent([1, 8])
      .translateExtent([[0, 0], [width, height]])
      .on('zoom', (event) => {
        const { transform } = event;
        zoomGroup.setAttribute('transform', transform.toString());
        currentZoomK = transform.k;
        const k = transform.k;

        zoomGroup.querySelectorAll('circle').forEach((c) => {
          const isBase = (c as SVGCircleElement).dataset.type === 'base';
          const baseR = isBase ? 4 : 3;
          c.setAttribute('r', String(baseR / k));
          c.setAttribute('stroke-width', String(0.8 / k));
        });

        zoomGroup.querySelectorAll('path').forEach((p) => {
          const original = (p as SVGPathElement).dataset.originalStrokeWidth;
          if (original) {
            p.setAttribute('stroke-width', String(Number(original) / k));
          }
        });

        zoomGroup.querySelectorAll('rect').forEach((r) => {
          const original = (r as SVGRectElement).dataset.originalStrokeWidth;
          if (original) {
            r.setAttribute('stroke-width', String(Number(original) / k));
          }
        });
      });

    // @ts-ignore d3-selection 类型和原生 SVGSVGElement 对接
    select(svgEl).call(zoomBehavior as any);

    if (loadingEl) loadingEl.remove();
  } catch (err) {
    if (loadingEl) loadingEl.textContent = '地图加载失败';
    console.error('Travel map error:', err);
  }
</script>

<style>
  .travel-main {
    padding: 120px 100px 100px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .travel-header { margin-bottom: 40px; }

  .travel-title {
    font-size: clamp(26px, 5vw, 32px);
    color: var(--slate-light);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .travel-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--slate-dark);
    max-width: 400px;
    margin-left: 20px;
  }
  .travel-title .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 20px;
    font-weight: 400;
  }

  .travel-desc {
    font-size: 15px;
    color: var(--slate);
    line-height: 1.6;
  }

  /* Map */
  .map-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    margin-bottom: 60px;
    background: var(--bg);
    border: 1px solid var(--slate-dark);
    border-radius: 6px;
    overflow: hidden;
  }
  #travel-map {
    width: 100%;
    height: 100%;
    display: block;
  }
  .map-tooltip {
    position: fixed;
    background: #0a192f;
    color: var(--slate-light, #ccd6f6);
    border: 1px solid #64ffda;
    padding: 6px 10px;
    font-size: 13px;
    font-family: var(--font-mono, ui-monospace, monospace);
    pointer-events: none;
    z-index: 10;
    white-space: nowrap;
    line-height: 1.4;
  }

  .map-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--slate);
    pointer-events: none;
  }

  /* Timeline */
  .timeline-section {
    max-width: 700px;
  }
  .year-group { margin-bottom: 40px; }
  .year-label {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 16px;
    letter-spacing: 0.05em;
  }
  .place-list { list-style: none; }
  .place-item {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 6px 0;
    font-size: 14px;
    color: var(--slate);
    line-height: 1.5;
    border-bottom: 1px solid rgba(73, 86, 112, 0.2);
  }
  .place-item:last-child { border-bottom: none; }

  .dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    position: relative;
    top: 1px;
  }
  .base-dot { background: #f59e0b; }
  .travel-dot { background: var(--accent); }

  .place-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate-dark);
    white-space: nowrap;
  }
  .place-sep { color: var(--slate-dark); }
  .place-label { color: var(--slate); }
  .base-item .place-label { color: var(--slate-light); }

  @media (max-width: 1099px) {
    .travel-main { padding: 120px 50px 100px; }
  }
  @media (max-width: 699px) {
    .travel-main { padding: 100px 20px 80px; }
  }
</style>
