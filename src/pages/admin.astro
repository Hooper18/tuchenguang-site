---
// 管理后台。极简前端硬编码校验：账号/密码写在 JS 里，懂查看源码的人能直接拿到。
// 这是"防一般人误入"级别，不是真安全。要真安全得上 Vercel Edge Middleware
// 或 Vercel 部署密码保护（Pro 计划）。
import BaseLayout from '../layouts/BaseLayout.astro';
import { trackedProjects, statsUpdatedAt, statsSourceNote } from '../data/admin-stats';
---

<BaseLayout
  lang="zh"
  title="管理后台"
  description=""
  hasAltLang={false}
  altLangHref="/"
  noIndex={true}
>
  <main class="admin-shell">
    <!-- login -->
    <section id="login-view" class="login-view" hidden>
      <form id="login-form" class="login-card" autocomplete="off">
        <h1>管理后台</h1>
        <p class="hint">仅站长访问。</p>
        <label>
          <span>账号</span>
          <input name="username" type="text" required autocomplete="off" />
        </label>
        <label>
          <span>密码</span>
          <input name="password" type="password" required autocomplete="off" />
        </label>
        <button type="submit">进入</button>
        <p id="login-error" class="error" hidden>账号或密码不对</p>
      </form>
    </section>

    <!-- dashboard -->
    <section id="dash-view" class="dash-view" hidden>
      <header class="dash-header">
        <div>
          <h1>流量统计</h1>
          <p class="dash-meta">{statsSourceNote}　·　更新于 {statsUpdatedAt}</p>
        </div>
        <button id="logout-btn" type="button">退出</button>
      </header>

      <table class="stats-table">
        <thead>
          <tr>
            <th class="col-name">项目</th>
            <th>近 7 天</th>
            <th>近 30 天</th>
            <th>累计</th>
            <th>最近访问</th>
          </tr>
        </thead>
        <tbody>
          {trackedProjects.map((p) => p.web ? (
            <tr>
              <td class="col-name">
                <a href={p.url} target="_blank" rel="noopener">{p.name}</a>
              </td>
              <td class="num">{p.web.visits7d.toLocaleString()}</td>
              <td class="num">{p.web.visits30d.toLocaleString()}</td>
              <td class="num">{p.web.visitsTotal.toLocaleString()}</td>
              <td class="num">{p.web.lastSeen}</td>
            </tr>
          ) : (
            <tr class="muted-row">
              <td class="col-name">
                <a href={p.url} target="_blank" rel="noopener">{p.name}</a>
              </td>
              <td colspan="4" class="muted">{p.note}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <footer class="dash-footer">
        <a href="/">← 返回主站</a>
      </footer>
    </section>
  </main>
</BaseLayout>

<script>
  const USER = 'admin';
  const PASS = 'tust';
  const KEY = 'adminAuth';

  const loginView = document.getElementById('login-view') as HTMLElement;
  const dashView = document.getElementById('dash-view') as HTMLElement;
  const loginForm = document.getElementById('login-form') as HTMLFormElement;
  const loginError = document.getElementById('login-error') as HTMLElement;
  const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;

  function show(view: 'login' | 'dash') {
    loginView.hidden = view !== 'login';
    dashView.hidden = view !== 'dash';
  }

  // boot
  const authed = sessionStorage.getItem(KEY) === 'ok';
  show(authed ? 'dash' : 'login');

  // login
  loginForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(loginForm);
    if (data.get('username') === USER && data.get('password') === PASS) {
      sessionStorage.setItem(KEY, 'ok');
      loginError.hidden = true;
      show('dash');
    } else {
      loginError.hidden = false;
    }
  });

  // logout
  logoutBtn.addEventListener('click', () => {
    sessionStorage.removeItem(KEY);
    show('login');
  });
</script>

<style>
  .admin-shell {
    min-height: 100vh;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
  }

  /* 登录视图 */
  .login-view {
    width: 100%;
    max-width: 360px;
    margin: 60px auto 0;
  }
  .login-card {
    background: var(--bg-light);
    border: 1px solid rgba(100, 255, 218, 0.1);
    border-radius: 6px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .login-card h1 {
    font-size: 18px;
    color: var(--slate-light);
    font-weight: 600;
    margin: 0;
  }
  .login-card .hint {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--slate);
    margin: -8px 0 4px;
  }
  .login-card label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--slate);
  }
  .login-card input {
    background: var(--bg);
    border: 1px solid rgba(100, 255, 218, 0.15);
    border-radius: 4px;
    color: var(--slate-light);
    font-family: var(--font-mono);
    font-size: 14px;
    padding: 10px 12px;
    transition: border-color 0.2s;
  }
  .login-card input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .login-card button {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 10px 16px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    margin-top: 6px;
  }
  .login-card button:hover {
    background: rgba(100, 255, 218, 0.08);
  }
  .login-card .error {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: #ff8585;
    margin: 0;
  }

  /* 仪表盘视图 */
  .dash-view {
    width: 100%;
    max-width: 900px;
    margin: 20px auto 0;
  }
  .dash-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .dash-header h1 {
    font-size: 22px;
    color: var(--slate-light);
    font-weight: 600;
    margin: 0 0 6px;
  }
  .dash-meta {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--slate);
    margin: 0;
  }
  #logout-btn {
    background: transparent;
    color: var(--slate);
    border: 1px solid var(--slate-dark);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    padding: 6px 14px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  #logout-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .stats-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .stats-table thead th {
    text-align: right;
    color: var(--slate);
    font-weight: 500;
    padding: 12px 14px;
    border-bottom: 1px solid var(--slate-dark);
  }
  .stats-table thead th.col-name { text-align: left; }
  .stats-table tbody td {
    padding: 14px;
    border-bottom: 1px solid rgba(100, 255, 218, 0.06);
    color: var(--slate-light);
    text-align: right;
  }
  .stats-table tbody td.col-name { text-align: left; }
  .stats-table tbody td.num { font-variant-numeric: tabular-nums; }
  .stats-table tbody td.muted { color: var(--slate); text-align: left; }
  .stats-table tbody .muted-row td.col-name a { color: var(--slate); }
  .stats-table tbody td.col-name a {
    color: var(--slate-light);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .stats-table tbody td.col-name a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .dash-footer {
    margin-top: 40px;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .dash-footer a {
    color: var(--accent);
    text-decoration: none;
  }
  .dash-footer a:hover { opacity: 0.7; }

  @media (max-width: 699px) {
    .admin-shell { padding: 60px 16px; }
    .stats-table thead th,
    .stats-table tbody td { padding: 10px 8px; font-size: 12px; }
  }
</style>
