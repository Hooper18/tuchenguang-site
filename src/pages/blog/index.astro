---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import SideLeft from '../../components/SideLeft.astro';
import SideRight from '../../components/SideRight.astro';
import Footer from '../../components/Footer.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="博客 — 涂晨光" description="涂晨光的博客，记录项目开发、留学生活和学到的新东西。">
  <Nav />
  <SideLeft />
  <SideRight />
  <main class="blog-list-main">
    <div class="blog-list-inner">
      <h1 class="blog-list-title reveal"><span class="num">博客</span></h1>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item reveal">
            <a href={`/blog/${post.id}`} class="post-link">
              <time class="post-date">{formatDate(post.data.pubDate)}</time>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <ul class="post-tags">
                  {post.data.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-list-main {
    padding: 0 100px;
    max-width: 1400px;
    margin: 0 auto;
    padding-top: 120px;
    padding-bottom: 100px;
  }
  .blog-list-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .blog-list-title {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: clamp(26px, 5vw, 32px);
    color: var(--slate-light);
    font-weight: 600;
    margin-bottom: 50px;
    letter-spacing: -0.01em;
  }
  .blog-list-title .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 20px;
    font-weight: 400;
  }
  .blog-list-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--slate-dark);
    max-width: 300px;
    margin-left: 20px;
  }
  .post-list { list-style: none; }
  .post-item { margin-bottom: 40px; }
  .post-link {
    display: block;
    text-decoration: none;
    padding: 24px;
    border: 1px solid var(--slate-dark);
    border-radius: 6px;
    transition: border-color 0.2s, background 0.2s;
  }
  .post-link:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .post-date {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .post-title {
    font-size: 20px;
    color: var(--slate-light);
    font-weight: 600;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .post-desc {
    font-size: 14.5px;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
  }
  .post-tags li {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 3px;
    padding: 2px 8px;
  }
  @media (max-width: 1099px) {
    .blog-list-main { padding: 120px 50px 100px; }
  }
  @media (max-width: 699px) {
    .blog-list-main { padding: 100px 20px 80px; }
  }
</style>
