---
import { getDict, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = getDict(lang);

const skills = ['Python', 'JavaScript', 'C / C++', 'React', 'Supabase', 'Tailwind CSS', 'Vercel', 'Git'];
---

<section id="about">
  <h2 class="section-heading reveal"><span class="num">01.</span>{t.about.sectionLabel}</h2>
  <div class="inner reveal">
    <div>
      <p>{t.about.p1Before}<strong>{t.about.p1Strong}</strong>{t.about.p1After}</p>
      <p><strong>{t.about.p2Strong}</strong>{t.about.p2After}</p>
      <p>{t.about.p3}</p>
      <p>{t.about.p4Before}<strong>{t.about.p4Strong}</strong>{t.about.p4After}</p>
      <p>{t.about.skillsLabel}</p>
      <ul class="skills-list">
        {skills.map((s) => <li>{s}</li>)}
      </ul>
    </div>
    <div>
      <div class="avatar-box"><div class="avatar"><img src="/images/avatar.jpg" alt={t.about.avatarAlt} /></div></div>
    </div>
  </div>
</section>
