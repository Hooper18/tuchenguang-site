---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BlogPostLayout from '../layouts/BlogPostLayout.astro';
import { splitBlogId, blogIndexHref, blogPostHref } from '../data/blog';
import type { Lang } from '../i18n';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
}

const { post, lang } = Astro.props;
const { Content } = await render(post);
const { slug } = splitBlogId(post.id);

// 检查另一语言是否存在该 slug。存在则镜像跳转 + 双向 hreflang；不存在则 lang
// 切换跳到对方博客列表（兜底避免 404），并抑制 hreflang 对端语言（避免误导
// 搜索引擎把列表页当作翻译版本）。
const otherLang: Lang = lang === 'zh' ? 'en' : 'zh';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const otherExists = allPosts.some((p) => {
  const parsed = splitBlogId(p.id);
  return parsed.slug === slug && parsed.lang === otherLang;
});
const altLangHref = otherExists ? blogPostHref(slug, otherLang) : blogIndexHref(otherLang);
---

<BlogPostLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  altLangHref={altLangHref}
  hasAltLang={otherExists}
>
  <Content />
</BlogPostLayout>
