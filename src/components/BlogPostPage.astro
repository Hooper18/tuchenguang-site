---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BlogPostLayout from '../layouts/BlogPostLayout.astro';
import { splitBlogId, blogIndexHref, blogPostHref } from '../data/blog';
import type { Lang } from '../i18n';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
}

const { post, lang } = Astro.props;
const { Content } = await render(post);
const { slug } = splitBlogId(post.id);

// 检查另一语言是否存在该 slug；存在则镜像跳转，否则跳到对方博客列表（避免 404）
const otherLang: Lang = lang === 'zh' ? 'en' : 'zh';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const otherExists = allPosts.some((p) => {
  const parsed = splitBlogId(p.id);
  return parsed.slug === slug && parsed.lang === otherLang;
});
const langSwitchHref = otherExists ? blogPostHref(slug, otherLang) : blogIndexHref(otherLang);
---

<BlogPostLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  langSwitchHref={langSwitchHref}
>
  <Content />
</BlogPostLayout>
