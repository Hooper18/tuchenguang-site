---
// 应用下载列表 — 主页 #apps 区段和 /apps 独立页共用。
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

interface ManifestEntry {
  versionCode: number;
  versionName: string;
  sizeBytes: number;
  downloadUrl: string;
  filename: string;
}

const manifestPath = resolve(process.cwd(), 'public/apps-manifest.json');
const manifest = JSON.parse(readFileSync(manifestPath, 'utf-8')) as Record<string, ManifestEntry>;

function formatSize(bytes: number) {
  return (bytes / 1024 / 1024).toFixed(1) + ' MB';
}

interface AppMeta {
  slug: string;
  name: string;
  iconAlt: string;
  desc: string;
  badge: '在线同步' | '完全离线';
  webUrl?: string;
}

const APPS: AppMeta[] = [
  {
    slug: 'schedule',
    name: '课程日历',
    iconAlt: '课程日历应用图标',
    desc: '学校 DDL 与课程自动记录。',
    badge: '在线同步',
    webUrl: 'https://calendar.tuchenguang.com',
  },
  {
    slug: 'ledger',
    name: '口袋记账',
    iconAlt: '口袋记账应用图标',
    desc: '多币种记账，统计、预算全免费。',
    badge: '在线同步',
    webUrl: 'https://ledger.tuchenguang.com',
  },
  {
    slug: 'billiards',
    name: '追分记',
    iconAlt: '追分记应用图标',
    desc: '三人台球计分。',
    badge: '完全离线',
    webUrl: 'https://billiards.tuchenguang.com',
  },
  {
    slug: 'tuner',
    name: 'Tuner',
    iconAlt: '吉他调音器应用图标',
    desc: '本地运行的吉他调音器。',
    badge: '完全离线',
    webUrl: 'https://tuner.tuchenguang.com',
  },
];

const apps = APPS.map((a) => {
  const m = manifest[a.slug];
  if (!m) throw new Error(`Missing apps-manifest entry for slug=${a.slug}`);
  return { ...a, manifest: m };
});
---

<ul class="app-list">
  {apps.map((app) => (
    <li class="app-row" id={app.slug}>
      <img src={`/icons/${app.slug}.png`} alt={app.iconAlt} class="app-icon" loading="lazy" />
      <div class="app-meta">
        <div class="app-headline">
          <h3 class="app-name">{app.name}</h3>
          <span class={`app-badge ${app.badge === '完全离线' ? 'badge-offline' : 'badge-sync'}`}>
            {app.badge}
          </span>
        </div>
        <p class="app-desc">{app.desc}</p>
        <div class="app-info">
          <span>v{app.manifest.versionName}</span>
          <span class="dot">·</span>
          <span>{formatSize(app.manifest.sizeBytes)}</span>
          {app.webUrl && (
            <>
              <span class="dot">·</span>
              <a href={app.webUrl} target="_blank" rel="noopener" class="web-link">网页版 ↗</a>
            </>
          )}
        </div>
      </div>
      <a href={app.manifest.downloadUrl} download class="dl-btn">下载 APK</a>
    </li>
  ))}
</ul>

<style>
  .app-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(136, 146, 176, 0.12);
    border-radius: 6px;
    overflow: hidden;
  }
  .app-row {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 22px 24px;
    background: var(--bg);
    transition: background 0.2s;
  }
  .app-row:hover {
    background: rgba(17, 34, 64, 0.5);
  }
  .app-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    flex-shrink: 0;
    object-fit: cover;
  }
  .app-meta {
    flex: 1;
    min-width: 0;
  }
  .app-headline {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }
  .app-name {
    font-size: 17px;
    color: var(--slate-light);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .app-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }
  .badge-sync {
    color: var(--accent);
    background: rgba(100, 255, 218, 0.08);
    border: 1px solid rgba(100, 255, 218, 0.25);
  }
  .badge-offline {
    color: var(--slate);
    background: rgba(136, 146, 176, 0.08);
    border: 1px solid rgba(136, 146, 176, 0.2);
  }
  .app-desc {
    font-size: 14px;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 8px;
  }
  .app-info {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .app-info .dot {
    color: var(--slate-dark);
  }
  .web-link {
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
  }
  .web-link:hover { color: var(--accent); }

  .dl-btn {
    flex-shrink: 0;
    padding: 10px 18px;
    border: 1px solid var(--accent);
    border-radius: 4px;
    color: var(--accent);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 13px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .dl-btn:hover { background: var(--accent-dim); }

  @media (max-width: 699px) {
    .app-row {
      flex-wrap: wrap;
      gap: 16px;
      padding: 18px 16px;
    }
    .app-meta { flex: 1 1 calc(100% - 80px); }
    .dl-btn { flex: 1 1 100%; text-align: center; }
    .app-icon { width: 48px; height: 48px; }
  }
</style>
