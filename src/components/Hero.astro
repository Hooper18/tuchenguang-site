---
import { getDict, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = getDict(lang);
---

<style>
  .hero-inline-link {
    color: var(--slate);
    text-decoration: none;
  }
</style>

<section id="hero">
  <div class="hero-intro">{t.hero.intro}</div>
  <h1 class="hero-name">{t.hero.name}</h1>
  <h2 class="hero-tagline">
    {lang === 'zh' ? (
      <><span class="cn">{t.hero.taglineLine1}</span><br />{t.hero.taglineLine2}</>
    ) : (
      <>{t.hero.taglineLine1}<br />{t.hero.taglineLine2}</>
    )}
  </h2>
  <p class="hero-desc">
    {t.hero.descBefore}<a href="#projects" class="hero-inline-link">{t.hero.descLink}</a>{t.hero.descAfter}
  </p>
  <a href="#projects" class="hero-cta">{t.hero.cta}</a>
</section>
