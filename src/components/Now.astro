---
import { nowItems } from '../data/now';

const statusClass = (status: string) => {
  if (status === 'active') return ' active';
  if (status === 'done') return ' done';
  return '';
};
---

<section id="now">
  <h2 class="section-heading reveal"><span class="num">03.</span>正在做</h2>
  <p class="now-updated reveal">最后一次更新时间：2026 年 4 月 26 日</p>
  <div class="now-timeline reveal">
    {nowItems.map((item) => (
      <div class={`now-item${statusClass(item.status)}`}>
        <span class="now-status">{item.label}</span>
        <h3 class="now-title">{item.title}</h3>
        {item.description && <p class="now-desc" set:html={item.description} />}
        {item.url && (
          <a class="now-link" href={item.url} target="_blank" rel="noopener noreferrer">
            {item.url.replace(/^https?:\/\//, '')}
          </a>
        )}
      </div>
    ))}
  </div>
</section>
