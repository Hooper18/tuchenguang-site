---
import { nowItems, pickText, nowLastUpdated } from '../data/now';
import { getDict, formatDate, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = getDict(lang);

const statusClass = (status: string) => {
  if (status === 'active') return ' active';
  if (status === 'done') return ' done';
  return '';
};
---

<section id="now">
  <h2 class="section-heading reveal"><span class="num">04.</span>{t.now.sectionLabel}</h2>
  <p class="now-updated reveal">{t.now.lastUpdatedPrefix}{formatDate(nowLastUpdated, lang)}</p>
  <div class="now-timeline reveal">
    {nowItems.map((item) => (
      <div class={`now-item${statusClass(item.status)}`}>
        <span class="now-status">{pickText(item.label, lang)}</span>
        <h3 class="now-title">{pickText(item.title, lang)}</h3>
        {pickText(item.description, lang) && <p class="now-desc" set:html={pickText(item.description, lang)} />}
        {item.url && (
          <a class="now-link" href={item.url} target="_blank" rel="noopener noreferrer">
            {item.url.replace(/^https?:\/\//, '')}
          </a>
        )}
      </div>
    ))}
  </div>
</section>
