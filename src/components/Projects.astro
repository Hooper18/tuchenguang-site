---
import PhoneCarousel from './PhoneCarousel.astro';
import { projects } from '../data/projects';
---

<section id="projects">
  <h2 class="section-heading reveal"><span class="num">02.</span>我做的东西</h2>

  {projects.map((project) => (
    <div class={`project reveal${project.reverse ? ' reverse' : ''}`}>
      <div class="project-content">
        <div class="project-overline">{project.overline}</div>
        <div class="project-header">
          <h3 class="project-title">
            <a href={project.titleHref} target="_blank">{project.title}</a>
          </h3>
          <a href={project.url} target="_blank" class="project-domain">
            {project.domain}
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M14 3h7v7M10 14L21 3M21 14v7h-7M3 10V3h7"/>
            </svg>
          </a>
        </div>
        <div class="project-description">{project.description}</div>
        <ul class="project-tech">
          {project.tech.map((t) => <li>{t}</li>)}
        </ul>
        <div class="project-links">
          {project.github && (
            <a href={project.github} target="_blank" aria-label="GitHub">
              <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 0a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.42-4.04-1.42-.55-1.4-1.33-1.77-1.33-1.77-1.09-.74.08-.73.08-.73 1.2.08 1.83 1.23 1.83 1.23 1.07 1.84 2.81 1.3 3.5 1 .1-.77.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.38.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 0z"/></svg>
            </a>
          )}
          <a href={project.url} target="_blank" aria-label="线上">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 3h7v7M10 14L21 3M21 14v7h-7M3 10V3h7"/></svg>
          </a>
        </div>
      </div>
      <div class="project-image">
        <PhoneCarousel images={project.images} id={project.slug} />
      </div>
    </div>
  ))}
</section>
