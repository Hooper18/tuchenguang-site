---
import PhoneCarousel from './PhoneCarousel.astro';
import HardwareCarousel from './HardwareCarousel.astro';
import { projects, pickText } from '../data/projects';
import { blogPostHref } from '../data/blog';
import { getDict, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = getDict(lang);
---

<section id="projects">
  <h2 class="section-heading reveal"><span class="num">02.</span>{t.projects.sectionLabel}</h2>

  {projects.map((project) => (
    <div class={`project reveal${project.reverse ? ' reverse' : ''}`}>
      <div class="project-content">
        <div class="project-overline">{project.overline}</div>
        <div class="project-header">
          <h3 class="project-title">
            {project.titleHref ? (
              <a href={project.titleHref} target="_blank">{pickText(project.title, lang)}</a>
            ) : (
              <span>{pickText(project.title, lang)}</span>
            )}
          </h3>
          {project.domain && project.url && (
            <a href={project.url} target="_blank" class="project-domain">
              {project.domain}
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M14 3h7v7M10 14L21 3M21 14v7h-7M3 10V3h7"/>
              </svg>
            </a>
          )}
        </div>
        <div class="project-description">{pickText(project.description, lang)}</div>
        <ul class="project-tech">
          {project.tech.map((tech) => <li>{tech}</li>)}
        </ul>
        <div class="project-links">
          {project.github && (
            <a href={project.github} target="_blank" aria-label={t.projects.githubAria}>
              <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 0a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.42-4.04-1.42-.55-1.4-1.33-1.77-1.33-1.77-1.09-.74.08-.73.08-.73 1.2.08 1.83 1.23 1.83 1.23 1.07 1.84 2.81 1.3 3.5 1 .1-.77.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.38.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 0z"/></svg>
            </a>
          )}
          {project.url && (
            <a href={project.url} target="_blank" aria-label={t.projects.liveAria}>
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 3h7v7M10 14L21 3M21 14v7h-7M3 10V3h7"/></svg>
            </a>
          )}
          {project.apkSlug && (
            <a href={`/#${project.apkSlug}`} class="apk-link" aria-label={t.projects.apkAria}>
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="2" width="12" height="20" rx="2" />
                <line x1="12" y1="18" x2="12.01" y2="18" />
              </svg>
              <span>{t.projects.apkLabel}</span>
            </a>
          )}
          {project.caseStudySlug && (
            <a href={blogPostHref(project.caseStudySlug, lang)} class="case-study-link" aria-label={t.projects.caseStudyAria}>
              {t.projects.caseStudyLabel}
            </a>
          )}
        </div>
      </div>
      <div class="project-image">
        {project.displayMode === 'hardware' ? (
          <HardwareCarousel images={project.images} id={project.slug} lang={lang} />
        ) : (
          <PhoneCarousel images={project.images} id={project.slug} lang={lang} />
        )}
      </div>
    </div>
  ))}
</section>

<style>
  /* APK 下载链接 — 比纯图标多一个文字标签，方便用户识别这是个安装包 */
  .apk-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate-light);
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
  }
  .apk-link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
  .apk-link svg {
    width: 16px;
    height: 16px;
  }
  /* 完整开发记录链接 — 用于硬件项目等没有 live URL 的卡片，指向博客长文 */
  .case-study-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate-light);
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
  }
  .case-study-link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
</style>
